APP_NAME=Laravel
APP_ENV=production
APP_KEY= ← SET THIS (php artisan key:generate)
APP_DEBUG=false
APP_TIMEZONE=UTC
APP_URL= ← SET THIS (Railway Backend Public URL)

LOG_CHANNEL=stack
LOG_STACK=single
LOG_LEVEL=info

DB_CONNECTION=mysql
DB_HOST= ← SET THIS (Railway MySQL Host)
DB_PORT=3306
DB_DATABASE= ← SET THIS (Railway MySQL Database)
DB_USERNAME= ← SET THIS (Railway MySQL User)
DB_PASSWORD= ← SET THIS (Railway MySQL Password)

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=reverb
FILESYSTEM_DISK=public
QUEUE_CONNECTION=database

CACHE_STORE=database
CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=log
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_ENCRYPTION=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

# Reverb
REVERB_APP_ID= ← SET THIS (e.g. 123456)
REVERB_APP_KEY= ← SET THIS (e.g. p4wrtmbchpdt0bkcszul)
REVERB_APP_SECRET= ← SET THIS
REVERB_HOST= ← SET THIS (Railway Backend Public URL without https://)
REVERB_PORT=443
REVERB_SCHEME=https

# Reverb Server (Internal)
REVERB_SERVER_HOST=0.0.0.0
REVERB_SERVER_PORT=8080

# JWT
JWT_SECRET= ← SET THIS (php artisan jwt:secret)

VITE_APP_NAME="${APP_NAME}"
VITE_REVERB_APP_KEY="${REVERB_APP_KEY}"
VITE_REVERB_HOST="${REVERB_HOST}"
VITE_REVERB_PORT="${REVERB_PORT}"
VITE_REVERB_SCHEME="${REVERB_SCHEME}"
